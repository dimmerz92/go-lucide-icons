package icons

templ ZodiacTaurus(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<circle cx="12" cy="15" r="6"></circle>
		<path d="M18 3A6 6 0 0 1 6 3"></path>
	</svg>
}
