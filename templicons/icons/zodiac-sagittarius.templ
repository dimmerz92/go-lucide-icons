package icons

templ ZodiacSagittarius(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M15 3h6v6"></path>
		<path d="M21 3 3 21"></path>
		<path d="m9 9 6 6"></path>
	</svg>
}
